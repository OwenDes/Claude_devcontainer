{
    //  ════════════════════════════════════════════════════════════════════════
    //  RÉGLAGES DE DURCISSEMENT VSCode — Dev Containers
    //  ════════════════════════════════════════════════════════════════════════
    //
    //  Ce fichier vit DANS le projet, donc il voyage avec le dossier (et avec
    //  Git si tu versionnes). Les réglages ci-dessous s'appliquent à quiconque
    //  ouvre ce projet, sur n'importe quelle machine (perso ou école).
    //
    //  ┌─────────────────────────────────────────┬──────────────────┬──────────────────────────────────────────────────────────────┐
    //  │ Réglage                                 │ État conseillé   │ Pourquoi                                                     │
    //  ├─────────────────────────────────────────┼──────────────────┼──────────────────────────────────────────────────────────────┤
    //  │ dev.containers.dockerCredentialHelper   │ false  (actif ↓) │ Coupe le partage des credentials Docker registry             │
    //  │ dev.containers.copyGitConfig            │ false  (actif ↓) │ Empêche la copie de ton .gitconfig (email, tokens, chemins)  │
    //  │ dev.containers.mountWaylandSocket       │ décoché *        │ Pont GUI (à décocher dans les settings VSCode de la machine) │
    //  │ dev.containers.forwardWSLServices       │ décoché *        │ SSH/GPG/X/Wayland forwardés depuis WSL                       │
    //  └─────────────────────────────────────────┴──────────────────┴──────────────────────────────────────────────────────────────┘
    //
    //  * mountWaylandSocket et forwardWSLServices sont des réglages MACHINE
    //    (liés à Podman/WSL sur Windows). Ils ne se mettent PAS proprement au
    //    niveau projet -> à décocher dans les User Settings de chaque machine.
    //    Sous Docker Desktop (école) ils ne sont pas indispensables, mais
    //    autant les laisser décochés par cohérence de durcissement.
    //
    //  Deux autres réglages que tu PEUX regarder, mais sans intérêt réel ici :
    //   - dev.containers.gitCredentialHelperConfigLocation : où VSCode injecte
    //     le helper Git. Sans objet, car dockerCredentialHelper=false + ASKPASS
    //     déjà coupé via le script de durcissement.
    //   - dev.containers.executeInWSL : concerne OÙ VSCode exécute, pas un pont
    //     de sécurité.
    //
    //  CONCLUSION : la vraie défense est dans l'IMAGE (script security-harden.sh
    //  du Dockerfile) + le devcontainer.json (remoteEnv), qui eux VOYAGENT.
    //  Les settings VSCode ne sont qu'une couche de surface, locale à la machine.
    //
    //  ── Réglage MACHINE à NE PAS mettre ici ───────────────────────────────────
    //  dev.containers.dockerPath : "podman" chez toi / "docker" à l'école.
    //  Dépend du moteur installé localement -> à régler en User Settings, pas ici.
    //  ════════════════════════════════════════════════════════════════════════

    "dev.containers.dockerCredentialHelper": false,
    "dev.containers.copyGitConfig": false
}
