{
    "name": "Claude Code Sandbox (durci, podman, home persistant)",
    "build": {
        "dockerfile": "Dockerfile"
    },

    "remoteUser": "node",
    "updateRemoteUserUID": true,
    "containerUser": "node",

    // Capacités requises par le pare-feu sortant (iptables/ipset).
    // Si le moteur les refuse, le conteneur démarre quand même : le
    // postStartCommand affiche alors un ⚠️ (sortie réseau non filtrée).
    "runArgs": [
        "--cap-add=NET_ADMIN",
        "--cap-add=NET_RAW"
    ],

    // ─── COUCHE 1 : neutralisation des variables d'environnement (ponts VSCode) ───
    "remoteEnv": {
        "SSH_AUTH_SOCK": "",
        "GPG_AGENT_INFO": "",
        "BROWSER": "",
        "VSCODE_IPC_HOOK_CLI": null,
        "VSCODE_GIT_IPC_HANDLE": null,
        "GIT_ASKPASS": null,
        "VSCODE_GIT_ASKPASS_MAIN": null,
        "VSCODE_GIT_ASKPASS_NODE": null,
        "VSCODE_GIT_ASKPASS_EXTRA_ARGS": null,
        "REMOTE_CONTAINERS_IPC": null,
        "REMOTE_CONTAINERS_SOCKETS": null,
        "REMOTE_CONTAINERS_DISPLAY_SOCK": null,
        "WAYLAND_DISPLAY": null,
        "DISPLAY": null
    },

    // ─── PERSISTANCE : un seul volume sur tout le home ───
    // Persiste d'un coup : .claude.json, .claude/, .bash_history, .config/,
    // et Claude Code lui-même (~/.local/bin). Init via init-home.sh.
    //
    // ── OPT-IN YubiKey (mode card) ──────────────────────────────────────
    // Pour utiliser une clé sur YubiKey via le gpg-agent de l'HÔTE, monte
    // le socket gpg-agent de l'hôte dans le trousseau pass du conteneur.
    // Ne PAS activer si tu n'utilises pas la YubiKey (par défaut : rien à
    // monter, tout marche en local). ⚠️ Suppose un gpg-agent qui tourne
    // côté WSL (socket Unix). Ajuste le chemin source à ton hôte, décommente
    // la ligne, et lis la section YubiKey du GUIDE.
    //   "source=${localEnv:HOME}/.gnupg/S.gpg-agent.extra,target=/home/node/.gnupg-pass/S.gpg-agent,type=bind"
    "mounts": [
        "source=claude-code-home,target=/home/node,type=volume"
    ],

    // NB : les réglages dev.containers.* (dockerCredentialHelper,
    // copyGitConfig) sont dans .vscode/settings.json — ici, dans
    // customizations, ils seraient appliqués DANS le conteneur après sa
    // création, donc trop tard pour agir.
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "anthropic.claude-code"
            ]
        }
    },

    // Init du volume home depuis le skel (seul usage de sudo autorisé,
    // avec init-firewall.sh — voir le sudoers restreint du Dockerfile).
    "postCreateCommand": "sudo /usr/local/bin/init-home.sh && claude --version",

    // Pare-feu sortant (à chaque démarrage : les règles ne persistent pas)
    // + nettoyage best-effort des sockets VSCode précoces.
    "postStartCommand": "sudo /usr/local/bin/init-firewall.sh || echo '⚠️ Pare-feu NON initialisé : sortie réseau non filtrée'; git config --global --unset-all credential.helper 'vscode-remote-containers' 2>/dev/null; find /tmp -maxdepth 2 \\( -name 'vscode-ssh-auth-*.sock' -o -name 'vscode-remote-containers-ipc-*.sock' -o -name 'vscode-remote-containers-*.js' -o -name 'vscode-ipc-*.sock' -o -name 'vscode-git-*.sock' \\) -delete 2>/dev/null || true"
}
